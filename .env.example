# Variáveis de Ambiente Necessárias

# ----------------------------------------------------
# Backend Node.js (.env raiz)
# ----------------------------------------------------
PORT=3000

# Credenciais de Serviço (Supabase) - Use a Service Role Key para acesso admin
SUPABASE_URL=https://[YOUR_INSTANCE].supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...[Sua_Service_Role_Key]

# Inteligência Artificial (OpenAI)
OPENAI_API_KEY=sk-...[Sua_OpenAI_Key]

# Integrações Futuras (Pagamentos/ERP)
ASAAS_API_KEY=seu_token_aqui

# Integração E-mail
RESEND_API_KEY=re_SUA_NOVA_CHAVE_AQUI
RESEND_FROM=DespesaGo <onboarding@resend.dev>
FRONTEND_URL=https://despesago.com.br


# ----------------------------------------------------
# Frontend React (também no .env raiz, lido pelo Vite)
# ----------------------------------------------------

# Credenciais Públicas (Seguras para o Frontend)
VITE_SUPABASE_URL=https://[YOUR_INSTANCE].supabase.co
VITE_SUPABASE_ANON_KEY=ey...[Sua_Anon_Key]
VITE_API_URL=https://despesago.com.br/api
